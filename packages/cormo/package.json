{
  "name": "cormo",
  "description": "ORM framework for Node.js",
  "version": "2.5.0",
  "keywords": [
    "orm",
    "mongodb",
    "mysql",
    "sqlite3",
    "postgresql"
  ],
  "homepage": "https://croquiscom.github.com/cormo",
  "bugs": {
    "url": "https://github.com/croquiscom/cormo/issues"
  },
  "author": "Sangmin Yoon <sangmin.yoon@croquis.com>",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./lib/cjs/index.js",
  "types": "./lib/cjs/index.d.ts",
  "exports": {
    "import": "./lib/esm/index.js",
    "require": "./lib/cjs/index.js"
  },
  "bin": {
    "cormo": "./bin/cormo"
  },
  "scripts": {
    "prepublishOnly": "npm run lint && npm run build",
    "build": "rimraf lib && tsc -b src/tsconfig.build.cjs.json src/tsconfig.build.esm.json && echo '{\"type\":\"commonjs\"}' > lib/cjs/package.json",
    "doc": "../../node_modules/.bin/typedoc src",
    "lint": "../../node_modules/.bin/eslint .",
    "test:type": "tsc --noEmit",
    "test:unit": "NODE_ENV=test TZ=Etc/UTC mocha -n import=tsx --timeout 5000 --exit 'test/*.{js,ts}'",
    "test": "npm run test:type && npm run lint && npm run test:unit --",
    "test:debug": "npm run test:unit -- --inspect-brk=30000",
    "test:cov": "c8 npm run test",
    "changeset": "changeset",
    "release": "npm run lint && npm run build && npm run changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/croquiscom/cormo.git"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "inflected": "^2.1.0",
    "ioredis": "^5.10.1",
    "lodash": "^4.17.23",
    "toposort-class": "^1.0.1",
    "tsimportlib": "^0.0.5",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/chai": "^5.2.3",
    "@types/inflected": "^2.1.3",
    "@types/lodash": "^4.17.24",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.12.0",
    "@types/sinon": "^21.0.0",
    "@types/yargs": "^17.0.35",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "mongodb": "^4.3.1",
    "mysql": "^2.18.1",
    "mysql2": "^3.20.0",
    "pg": "^8.20.0",
    "pg-query-stream": "^4.14.0",
    "rimraf": "^6.1.3",
    "sinon": "^21.0.3",
    "sqlite3": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "c8": {
    "extension": [
      ".ts"
    ],
    "reporter": [
      "lcov"
    ]
  },
  "overrides": {
    "mocha": {
      "diff": "8.0.4",
      "serialize-javascript": "7.0.5"
    }
  }
}
